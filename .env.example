# QuantMap Environment Configuration
# Copy this file to .env and fill in your paths.
# All QUANTMAP_* variables are read at import time via python-dotenv.

# ---------------------------------------------------------------------------
# REQUIRED — QuantMap will not start without these
# ---------------------------------------------------------------------------

# Path to your llama-server binary (llama.cpp build with CUDA support)
QUANTMAP_SERVER_BIN=D:/.store/tools/llama.cpp/build-B/bin/llama-server.exe

# Path to your model file (first shard if multi-shard GGUF)
QUANTMAP_MODEL_PATH=D:/.store/models/MiniMax-M2.5/UD-Q3_K_XL/MiniMax-M2.5-UD-Q3_K_XL-00001-of-00004.gguf

# Lab root directory — where results/, logs/, db/, state/ are stored
# Must be an absolute path. All runtime outputs go here.
QUANTMAP_LAB_ROOT=D:/Workspaces/QuantMap

# ---------------------------------------------------------------------------
# OPTIONAL — have sensible defaults if unset
# ---------------------------------------------------------------------------

# Intel oneAPI MKL root (required if your llama.cpp build links against MKL)
# Default: C:/Program Files (x86)/Intel/oneAPI/mkl/latest
QUANTMAP_MKL_ROOT=C:/Program Files (x86)/Intel/oneAPI/mkl/latest

# Intel oneAPI Compiler root (for compiler runtime DLLs)
# Default: C:/Program Files (x86)/Intel/oneAPI/compiler/latest
QUANTMAP_COMPILER_ROOT=C:/Program Files (x86)/Intel/oneAPI/compiler/latest

# CUDA toolkit path (for CUDA runtime DLLs)
# Default: C:/Program Files/NVIDIA GPU Computing Toolkit/CUDA/v12.6
QUANTMAP_CUDA_PATH=C:/Program Files/NVIDIA GPU Computing Toolkit/CUDA/v12.6

# Host to bind llama-server and use in production commands
# Default: 127.0.0.1 (loopback only — lab measurements never go over the network)
# QUANTMAP_SERVER_HOST=127.0.0.1

# Server startup timeouts (seconds)
# Bind timeout: max wait for server port to open (large models take longer)
# Ready timeout: max wait for first completion request to succeed
# QUANTMAP_SERVER_BIND_TIMEOUT=300
# QUANTMAP_SERVER_READY_TIMEOUT=120

# Override paths for configs/ and requests/ directories
# Default: relative to the repo root (configs/ and requests/)
# QUANTMAP_CONFIGS_DIR=D:/Workspaces/QuantMap/configs
# QUANTMAP_REQUESTS_DIR=D:/Workspaces/QuantMap/requests
